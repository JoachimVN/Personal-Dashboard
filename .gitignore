# Dependencies
node_modules/

# Builds
client/dist/
server/dist/

# Secrets — never commit these
.env
.env.*
!.env.example
server/.tokens/

# Personal settings (calendar names, feeds, local repo paths).
# Start from server/config.example.json — a missing config.json just uses defaults.
server/config.json

# Local data (AI usage history, …)
server/.data/

# Logs & OS noise
*.log
.DS_Store
/.vscode
/.claude
