# Dependencies
node_modules/

# Builds
client/dist/
server/dist/

# Secrets — never commit these
.env
.env.*
!.env.example
# No trailing slash: install-launchd.sh replaces these with symlinks into the shared
# state dir, and a trailing-slash pattern matches only real directories — so `foo/`
# would silently stop ignoring them the moment they become links.
server/.tokens
server/.data

# Personal settings (calendar names, feeds, local repo paths).
# Start from server/config.example.json — a missing config.json just uses defaults.
server/config.json

# Logs & OS noise
*.log
.DS_Store
/.vscode
/.claude
