# Copy to .env and fill in. Everything here is optional — widgets whose
# credentials are missing show as "disabled" instead of breaking.

# Core
DASHBOARD_TIMEZONE=Europe/Oslo
PORT=4821
# HOST is loopback by default; phone access goes through `tailscale serve 4821`.
# Setting HOST=0.0.0.0 exposes the dashboard unauthenticated on your LAN — opt-in only.
# HOST=0.0.0.0

# Weather (MET Norway — no key, just coordinates)
# WEATHER_LAT=63.4305
# WEATHER_LON=10.3951

# GitHub (fine-grained PAT — see README for exact permissions)
# GITHUB_TOKEN=
# GITHUB_USERNAME=

# iCloud Calendar (app-specific password from appleid.apple.com)
# ICLOUD_USERNAME=
# ICLOUD_APP_PASSWORD=

# Gmail (OAuth desktop client — run `npm run setup:gmail` after filling these)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
