# Copy to .env and fill in. DATABASE_URL is required because dashboard history is
# shared through Postgres; other widget credentials remain optional.

# Core
DASHBOARD_TIMEZONE=Europe/Oslo
PORT=4821
# Railway Postgres public connection URL. Keep it secret; it contains credentials.
# DATABASE_URL=
# HOST is loopback by default; phone access goes through `tailscale serve 4821`.
# Setting HOST=0.0.0.0 exposes the dashboard unauthenticated on your LAN — opt-in only.
# HOST=0.0.0.0

# Weather (MET Norway — no key, just coordinates)
# WEATHER_LAT=59.9139
# WEATHER_LON=10.7522

# GitHub (classic PAT with the `repo` scope — a fine-grained PAT does not work,
# see the README: the activity feed's events API doesn't support them)
# GITHUB_TOKEN=
# GITHUB_USERNAME=

# Optional, for the "capture issue" button. Falls back to GITHUB_TOKEN when unset.
# GITHUB_ISSUES_TOKEN=

# iCloud Calendar (app-specific password from account.apple.com)
# ICLOUD_USERNAME=
# ICLOUD_APP_PASSWORD=

# Gmail (OAuth desktop client — run `npm run setup:gmail -w server` after filling these)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Spotify (run `npm run setup:spotify -w server` after filling these)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Philips Hue Remote API (run `npm run setup:hue -w server` after filling these)
# HUE_CLIENT_ID=
# HUE_CLIENT_SECRET=

# Steam Web API
# STEAM_API_KEY=
# STEAM_ID=

# Roblox (ROBLOX_ID accepts a username or numeric user ID; ROBLOSECURITY is optional —
# only needed for presence/favorites, and is a full-account session cookie, not a
# scoped key. Grab it from a logged-in browser: DevTools > Application/Storage >
# Cookies > roblox.com > .ROBLOSECURITY. Keep the "_|WARNING:..." prefix, it's part
# of the value. It expires/rotates periodically and will need refreshing.)
# ROBLOX_ID=
# ROBLOSECURITY=

# Clash Royale (developer.clashroyale.com — key is IP-locked to whatever address
# is making requests, re-key if your public IP changes)
# CLASH_ROYALE_API_KEY=
# CLASH_ROYALE_ID=

# SonarCloud (user token + your org key, from sonarcloud.io/organizations/<key>)
# SONARCLOUD_TOKEN=
# SONARCLOUD_ORG=
