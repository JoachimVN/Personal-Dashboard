{
  "name": "@personal-dashboard/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "predev": "cross-env PORT=4822 tsx scripts/freePort.ts",
    "dev": "cross-env PORT=4822 tsx watch src/index.ts",
    "start": "cross-env NODE_ENV=production tsx src/index.ts",
    "test": "vitest run",
    "setup:gmail": "tsx scripts/setupGmail.ts",
    "setup:spotify": "tsx scripts/setupSpotify.ts",
    "setup:hue": "tsx scripts/setupHue.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:import-json": "tsx scripts/importJsonToPostgres.ts",
    "seed:spotify-streams": "tsx scripts/seedSpotifyStreams.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@personal-dashboard/shared": "*",
    "ccusage": "20.0.17",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.4",
    "express": "^5.1.0",
    "googleapis": "^173.0.0",
    "node-ical": "^0.26.1",
    "octokit": "^5.0.5",
    "postgres": "^3.4.7",
    "rss-parser": "^3.13.0",
    "tsdav": "^2.3.1",
    "tsx": "^4.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
